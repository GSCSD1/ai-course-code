   "source": [
    "import numpy as np\n",
    "\n",
    "\"\"\"\n",
    "    normal: 从具有指定平均值和标准差的正态分布中抽取样本\n",
    "    numpy.random.normal(loc=0.0, scale=1.0, size=None)\n",
    "    loc：正态分布的均值。\n",
    "    scale： 标准差\n",
    "    size：输出数组的形状，它可以是整数也可以时元组\n",
    "\"\"\"\n",
    "\n",
    "# 生成50均值为5，标准差为2的正态分布\n",
    "# 68数据落在  [3,7]范围\n",
    "\n",
    "print(np.random.normal(5,2,50))"
   ],
