   "source": [
    "\"\"\"\n",
    "    vsplit: 沿着垂直方向将数组分割成多个子数组\n",
    "    numpy.vsplit(ary, indices_or_sections)\n",
    "\"\"\"\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "arr = np.arange(12).reshape(4,3)\n",
    "print('原数组：\\n',arr)\n",
    "\n",
    "result = np.vsplit(arr,2)\n",
    "print('垂直方向分割成2个子数组：\\n',result)\n",
    "\n"
   ],
   "id": "5edb400664eaaa49",
   "outputs": [
    {
     "name": "stdout",
