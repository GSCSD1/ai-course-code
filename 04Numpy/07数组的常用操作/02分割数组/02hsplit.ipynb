   "source": [
    "\"\"\"\n",
    "    hsplit: 沿着水平方向将数组分割成多个子数组\n",
    "    numpy.hsplit(ary, indices_or_sections)\n",
    "\"\"\"\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "arr = np.arange(12).reshape(4,3)\n",
    "print('原数组：\\n',arr)\n",
    "\n",
    "result = np.hsplit(arr,3)\n",
    "print('水平方向分割成3个子数组：\\n',result)\n",
    "\n"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
