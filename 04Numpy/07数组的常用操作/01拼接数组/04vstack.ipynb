   "source": [
    "\"\"\"\n",
    "    vstack： 垂直堆叠  是 concatenate 的简化版\n",
    "    numpy.vstack(tup)\n",
    "    tup：一个数组序列，它们被垂直堆叠在一起。所有的数组除了0轴以外必须具有相同的形状\n",
    "\"\"\"\n",
    "import numpy as np\n",
    "arr1 = np.random.randint(10,size=(2,3))\n",
    "arr2 = np.random.randint(10,size=(2,3))\n",
    "print(arr1)\n",
    "print(arr2)\n",
    "\n",
    "print(np.vstack((arr1,arr2)))"
   ],
