   "source": [
    "\"\"\"\n",
    "    hstack : 水平堆叠  是concatenate的简化版本\n",
    "    numpy.hstack(tup)\n",
    "    tup：一个数组序列，它们被水平堆叠在一起。所有的数组除了1轴以外必须具有相同的形状\n",
    "\"\"\"\n",
    "import numpy as np\n",
    "\n",
    "arr1 = np.random.randint(10,size=(2,3))\n",
    "arr2 = np.random.randint(10,size=(2,3))\n",
    "print(arr1)\n",
    "print(arr2)\n",
    "\n",
    "# 水平堆叠\n",
    "print(np.hstack((arr1,arr2)))\n"
   ],
