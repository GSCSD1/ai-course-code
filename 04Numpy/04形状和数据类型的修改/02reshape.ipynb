   "source": [
    "\"\"\"\n",
    "    用于给数组一个新的形状而不改变其数据，它返回的是一个新的数组\n",
    "    如果给定的形状与原始数据不兼容会报错\n",
    "    reshape(newshape, order='C')\n",
    "\"\"\"\n",
    "import numpy as np\n",
    "\n",
    "# 创建2行3列全10数组\n",
    "arr1 = np.full((2,3),10)\n",
    "print(arr1)\n",
    "# 改变形状为3行2列\n",
    "print(arr1.reshape(3, 2))"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[10 10 10]\n",
      " [10 10 10]]\n",
      "[[10 10]\n",
      " [10 10]\n",
      " [10 10]]\n"
     ]
    }
   ],
   "execution_count": 4
