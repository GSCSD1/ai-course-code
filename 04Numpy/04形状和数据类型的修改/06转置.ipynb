   "cell_type": "code",
   "source": [
    "import numpy as np\n",
    "# 创建一个二维数组   # 转置 ： 行列交互\n",
    "arr_2d = np.array([[1, 2], [3, 4], [5, 6]])\n",
    "# 获取转置\n",
    "transposed_arr = arr_2d.T\n",
    "print(\"Original array:\")\n",
    "print(arr_2d)\n",
    "print(\"Transposed array:\")\n",
    "print(transposed_arr)"
   ],
   "id": "33e305d4380b0aaa",
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original array:\n",
      "[[1 2]\n",
      " [3 4]\n",
      " [5 6]]\n",
      "Transposed array:\n",
      "[[1 3 5]\n",
      " [2 4 6]]\n"
     ]
    }
   ],
