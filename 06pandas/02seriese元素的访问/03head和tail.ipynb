   "source": [
    "\"\"\"\n",
    "     head: 快速查看Series数据的开头部分内容\n",
    "     tail: 快速查看Series数据的末尾部分内容\n",
    "    series.head(n=None)\n",
    "    series.tail(n=None)\n",
    "\n",
    "    n: None:值为5  指定要返回的行数\n",
    "\"\"\"\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "series = pd.Series(np.random.rand(100))\n",
    "# print(series.head(20))\n",
    "\n",
    "print(series.tail(20))"
   ],
